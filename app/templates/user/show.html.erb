<section class="section">
  <div class="container">
    <div class="level">
      <div class="level-left">
        <%= render "shared/avatar", avatar_url:, avatar_size: 64 %>
        <h1 class="title ml-3"><%= display_name || user_name %></h1>
      </div>
    </div>
    <p class="subtitle">@<%= user_name %></p>
  </div>

  <% if is_owner %>
    <div class="container mt-5">
      <div class="tabs" data-tabs="user-edit">
        <ul>
          <li data-target="edit-maps" class="is-active"><a><span class="icon-text"><span class="icon"><i class="fa-solid fa-map"></i></span><span><%= t("user-tab-maps") %></span></span></a></li>
          <li data-target="edit-profile"><a><span class="icon-text"><span class="icon"><i class="fa-solid fa-circle-user"></i></span><span><%= t("user-tab-profile") %></span></span></a></li>
          <li data-target="edit-preferences"><a><span class="icon-text"><span class="icon"><i class="fa-solid fa-gear"></i></span><span><%= t("user-tab-preferences") %></span></span></a></li>
          <li data-target="edit-credentials"><a><span class="icon-text"><span class="icon"><i class="fa-solid fa-link"></i></span><span><%= t("user-tab-credentials") %></span></span></a></li>
          <li data-target="edit-danger"><a><span class="icon-text"><span class="icon has-text-danger"><i class="fa-solid fa-triangle-exclamation"></i></span><span><%= t("user-tab-danger") %></span></span></a></li>
        </ul>
      </div>

      <div id="edit-maps" data-tab-panel="user-edit">
        <% unless recent_map_infos.empty? %>
          <div class="columns is-multiline">
            <% recent_map_infos.each do |map_info| %>
              <div class="column is-half-tablet is-one-quarter-desktop">
                <%= render "maps/map_card",
                      map_ulid: map_info.ulid,
                      map_display_name: map_info.display_name,
                      user_name: map_info.user_info.name,
                      author_display_name: map_info.user_info.display_name,
                      author_avatar_url: map_info.user_info.avatar_url,
                      thumbnail_url: map_info.thumbnail_url,
                      metadata_url: map_info.metadata_url,
                      updated_at: map_info.updated_at %>
              </div>
            <% end %>
          </div>
          <script src="<%= island_src("map_info_button") %>" type="module"></script>
          <script src="<%= island_src("share_buttons") %>" type="module"></script>
        <% end %>
      </div>

      <div id="edit-profile" class="is-hidden" data-tab-panel="user-edit">
        <% if error %>
          <div class="notification is-danger is-light"><%= error %></div>
        <% end %>
        <form action="<%= path(:user_profile, user_name:) %>" method="post">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
          <div class="field">
            <p class="label">
              <span class="icon-text">
                <span class="icon"><i class="fa-solid fa-user"></i></span>
                <span><%= t("edit-avatar-label") %></span>
              </span>
            </p>
            <div class="control" id="avatar-upload"
                 data-current-avatar-url="<%= avatar_url %>"
                 data-user-name="<%= user_name %>"></div>
          </div>
          <div class="field">
            <label class="label" for="display_name">
              <span class="icon-text">
                <span class="icon"><i class="fa-solid fa-address-card"></i></span>
                <span><%= t("edit-display-name") %></span>
              </span>
            </label>
            <div class="control">
              <input class="input" type="text" id="display_name" name="display_name"
                     value="<%= display_name %>"
                     maxlength="64">
            </div>
            <p class="help"><%= t("edit-display-name.help") %></p>
          </div>
          <div class="field">
            <div class="control">
              <button class="button is-primary" type="submit">
                <span class="icon"><i class="fa-solid fa-floppy-disk"></i></span>
                <span><%= t("edit-save-profile") %></span>
              </button>
              <a class="button ml-2" href="<%= path(:root) %>">
                <span><%= t("edit-cancel") %></span>
              </a>
            </div>
          </div>
        </form>
      </div>

      <div id="edit-preferences" class="is-hidden" data-tab-panel="user-edit">
        <form action="<%= path(:user_preferences, user_name:) %>" method="post">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
          <div class="field">
            <label class="label" for="timezone-select">
              <span class="icon-text">
                <span class="icon"><i class="fa-solid fa-clock"></i></span>
                <span><%= t("edit-timezone-label") %></span>
              </span>
            </label>
            <div class="control is-flex is-align-items-center">
              <div class="select">
                <select id="timezone-select" name="timezone">
                  <% timezone_identifiers.group_by { |tz| tz.include?("/") ? tz.split("/").first : "Other" }.each do |region, tzs| %>
                    <optgroup label="<%= region %>">
                      <% tzs.each do |tz| %>
                        <option value="<%= tz %>"<%= " selected" if tz == timezone %>><%= tz %></option>
                      <% end %>
                    </optgroup>
                  <% end %>
                </select>
              </div>
              <span class="ml-3" id="timezone-time"></span>
            </div>
          </div>
          <div class="field">
            <label class="label" for="locale-select">
              <span class="icon-text">
                <span class="icon"><i class="fa-solid fa-language"></i></span>
                <span><%= t("edit-locale") %></span>
              </span>
            </label>
            <div class="control">
              <div class="select">
                <select id="locale-select" name="locale">
                  <option value=""<%= " selected" if locale.nil? || locale.empty? %>><%= t("edit-locale.use-browser") %></option>
                  <% supported_locales.each do |loc| %>
                    <option value="<%= loc %>"<%= " selected" if locale == loc %>><%= locale_name(loc) %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>
          <div class="field">
            <div class="control">
              <button class="button is-primary" type="submit">
                <span class="icon"><i class="fa-solid fa-floppy-disk"></i></span>
                <span><%= t("edit-save-preferences") %></span>
              </button>
              <a class="button ml-2" href="<%= path(:root) %>">
                <span><%= t("edit-cancel") %></span>
              </a>
            </div>
          </div>
        </form>
      </div>

      <div id="edit-credentials" class="is-hidden" data-tab-panel="user-edit">
        <div class="field">
          <% only_one = connected_providers.size <= 1 %>
          <div class="level">
            <div class="level-left">
              <% providers.each do |provider| %>
                <div class="level-item">
                  <% if connected_providers.include?(provider) %>
                    <form action="<%= path(:user_credential, user_name:, provider:) %>" method="post">
                      <input type="hidden" name="_method" value="delete">
                      <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
                      <button class="button is-danger is-light" type="submit"<% if only_one %> disabled title="<%= t("credential-last-hint") %>"<% end %>>
                        <span class="icon"><i class="fa-brands fa-<%= provider %>"></i></span>
                        <span><%= t("credential-disconnect-#{provider}") %></span>
                      </button>
                    </form>
                  <% else %>
                    <form action="/auth/<%= provider %>" method="post">
                      <input type="hidden" name="authenticity_token" value="<%= omniauth_authenticity_token %>">
                      <button class="button" type="submit">
                        <span class="icon"><i class="fa-brands fa-<%= provider %>"></i></span>
                        <span><%= t("credential-connect-#{provider}") %></span>
                      </button>
                    </form>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div id="edit-danger" class="is-hidden" data-tab-panel="user-edit">
        <p class="mb-3"><%= t("account-delete-warning") %></p>
        <form action="/@<%= user_name %>" method="post" data-confirm-delete="true">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
          <input type="hidden" name="user_name" value="<%= user_name %>">
          <div class="field">
            <label class="label" for="confirm_user_name"><%= t("account-delete-confirm-label") %></label>
            <div class="control">
              <input class="input" type="text" id="confirm_user_name" name="confirm_user_name"
                     autocomplete="off" data-confirm-username="<%= user_name %>">
            </div>
          </div>
          <div class="field">
            <div class="control">
              <button class="button is-danger" type="submit" id="delete-account-button" disabled>
                <span class="icon"><i class="fa-solid fa-trash"></i></span>
                <span><%= t("account-delete-button") %></span>
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  <% else %>
    <% unless recent_map_infos.empty? %>
      <div class="container mt-5">
        <h2 class="title is-4">
          <span class="icon-text">
            <span class="icon"><i class="fa-solid fa-map"></i></span>
            <span><%= t("user-recent-maps") %></span>
          </span>
        </h2>
        <div class="columns is-multiline">
          <% recent_map_infos.each do |map_info| %>
            <div class="column is-half-tablet is-one-quarter-desktop">
              <%= render "maps/map_card",
                    map_ulid: map_info.ulid,
                    map_display_name: map_info.display_name,
                    user_name: map_info.user_info.name,
                    author_display_name: map_info.user_info.display_name,
                    author_avatar_url: map_info.user_info.avatar_url,
                    thumbnail_url: map_info.thumbnail_url,
                    metadata_url: map_info.metadata_url,
                    updated_at: map_info.updated_at %>
            </div>
          <% end %>
        </div>
        <script src="<%= island_src("map_info_button") %>" type="module"></script>
        <script src="<%= island_src("share_buttons") %>" type="module"></script>
      </div>
    <% end %>
  <% end %>
</section>
