<% if avatar_url %>
  <img src="<%= avatar_url %>" width="<%= avatar_size %>" height="<%= avatar_size %>" style="border-radius:50%;object-fit:cover;vertical-align:middle">
<% else %>
  <i class="fa-solid fa-circle-user" style="font-size:<%= avatar_size %>px;line-height:1;vertical-align:middle"></i>
<% end %>
