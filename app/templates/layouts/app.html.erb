<!DOCTYPE html>
<html lang="<%= locale_tag %>">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrf_token %>">
    <title><%= t("app-name") %></title>
    <%= favicon_tag %>
    <%= stylesheet_tag "app" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;700;900&display=swap" rel="stylesheet">
    <% if (canonical_url = content_for(:canonical_url)) %><link rel="canonical" href="<%= canonical_url %>"><% end %>
    <% if (og = content_for(:og_data)) %>
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="<%= t("app-name") %>">
    <meta property="og:title" content="<%= og[:title] %>">
    <meta property="og:description" content="<%= og[:description] %>">
    <% if canonical_url %><meta property="og:url" content="<%= canonical_url %>"><% end %>
    <% if og[:image] %><meta property="og:image" content="<%= og[:image] %>"><% end %>
    <% if og[:updated_time] %><meta property="article:modified_time" content="<%= og[:updated_time] %>"><% end %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= og[:title] %>">
    <meta name="twitter:description" content="<%= og[:description] %>">
    <% if og[:image] %><meta name="twitter:image" content="<%= og[:image] %>"><% end %>
    <% end %>
  </head>
  <body>
    <nav class="navbar" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item" href="<%= path(:root) %>"><strong><%= t("app-name") %></strong></a>
        <div class="navbar-item" id="upload-modal" data-guest="<%= current_user_name ? 'false' : 'true' %>"></div>
        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbar-main">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>
      <div id="navbar-main" class="navbar-menu">
        <div id="navbar-end" class="navbar-end"
             data-user-name="<%= current_user_name || "" %>"
             data-display-name="<%= current_user_display_name || "" %>"
             data-avatar-url="<%= current_avatar_url || "" %>"
             data-user-path="<%= current_user_name ? path(:user, user_name: current_user_name) : "" %>"
             data-logout-path="<%= current_user_name ? path(:auth_session) : "" %>"
             data-csrf-token="<%= csrf_token %>"
             data-omniauth-token="<%= omniauth_authenticity_token %>"></div>
      </div>
    </nav>
    <% if flash_notice %>
      <div class="container mt-4 px-4">
        <div class="notification is-success is-light">
          <button class="delete"></button>
          <%= t(flash_notice) %>
        </div>
      </div>
    <% end %>
    <% if flash_error %>
      <div class="container mt-4 px-4">
        <div class="notification is-danger is-light">
          <button class="delete"></button>
          <%= t(flash_error) %>
        </div>
      </div>
    <% end %>
    <%= yield %>
    <%= render "shared/footer" %>
    <script src="<%= island_src("upload_modal") %>" type="module"></script>
    <script src="<%= island_src("avatar_upload") %>" type="module"></script>
    <script src="<%= island_src("footer") %>" type="module"></script>
    <script src="<%= island_src("navbar_end") %>" type="module"></script>
    <%= javascript_tag "app" %>
  </body>
</html>
