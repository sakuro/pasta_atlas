<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrf_token %>">
    <title>Pasta Atlas</title>
    <%= favicon_tag %>
    <%= stylesheet_tag "app" %>
  </head>
  <body>
    <nav class="navbar" role="navigation" aria-label="main navigation">
      <div class="navbar-brand">
        <a class="navbar-item" href="/"><strong>Pasta Atlas</strong></a>
        <div class="navbar-item" id="upload-modal" data-guest="<%= current_user_name ? 'false' : 'true' %>"></div>
        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="false" data-target="navbar-main">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </a>
      </div>
      <div id="navbar-main" class="navbar-menu">
        <div class="navbar-end">
          <% if current_user_name %>
            <a class="navbar-item" href="/@<%= current_user_name %>/profile">
              <%= render "shared/avatar", avatar_url: current_avatar_url, avatar_size: 24 %>
              <span class="ml-2"><%= current_user_display_name %></span>
            </a>
            <form action="/auth/session" method="post" style="display: contents">
              <input type="hidden" name="_method" value="delete">
              <input type="hidden" name="_csrf_token" value="<%= csrf_token %>">
              <button class="navbar-item" type="submit">
                <span class="icon"><i class="fa-solid fa-arrow-right-from-bracket"></i></span>
                <span>Log out</span>
              </button>
            </form>
          <% else %>
            <div class="navbar-item has-dropdown is-hoverable">
              <a class="navbar-link">
                <span class="icon"><i class="fa-solid fa-arrow-right-to-bracket"></i></span>
                <span>Log in</span>
              </a>
              <div class="navbar-dropdown is-right">
                <form action="/auth/github" method="post">
                  <input type="hidden" name="authenticity_token" value="<%= omniauth_authenticity_token %>">
                  <button class="navbar-item" type="submit">
                    <span class="icon"><i class="fa-brands fa-github"></i></span>
                    <span>Log in with GitHub</span>
                  </button>
                </form>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </nav>
    <%= yield %>
    <footer class="footer">
      <div class="content has-text-centered">
        <p>
          &copy; 2026 Built with
          <a href="https://www.ruby-lang.org/" target="_blank" rel="noopener">Ruby</a> &middot;
          <a href="https://hanakai.org/hanami" target="_blank" rel="noopener">Hanami</a> &middot;
          <a href="https://www.solidjs.com/" target="_blank" rel="noopener">SolidJS</a> &middot;
          <a href="https://bulma.io/" target="_blank" rel="noopener">Bulma</a> &middot;
          <a href="https://leafletjs.com/" target="_blank" rel="noopener">Leaflet</a> &middot;
          <a href="https://fontawesome.com/" target="_blank" rel="noopener">Font Awesome</a>
        </p>
        <p>
          <a href="https://github.com/sakuro/pasta_atlas" target="_blank" rel="noopener">
            <span class="icon"><i class="fa-brands fa-github"></i></span>
            <span>Source code</span>
          </a>
        </p>
      </div>
    </footer>
    <script src="<%= island_src("upload_modal") %>" type="module"></script>
    <script src="<%= island_src("avatar_upload") %>" type="module"></script>
    <%= javascript_tag "app" %>
  </body>
</html>
