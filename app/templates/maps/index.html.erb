<section class="hero">
  <div class="hero-body p-0">
    <%= image_tag "hero.webp", alt: t("app-name"), style: "width: 100%; height: 360px; object-fit: cover; object-position: bottom; display: block;" %>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="columns is-multiline">
      <% maps.each do |map| %>
        <% user_info = user_infos_by_user_id[map.user_id] %>
        <% map_info = map_infos_by_ulid[map.ulid] %>
        <div class="column is-half-tablet is-one-quarter-desktop">
          <%= render "map_card",
                map_ulid: map.ulid,
                map_display_name: map.display_name,
                user_name: user_info.name,
                author_display_name: user_info.display_name,
                author_avatar_url: user_info.avatar_url,
                thumbnail_url: map_info.thumbnail_url,
                metadata_url: map_info.metadata_url,
                updated_at: map_info.updated_at %>
        </div>
      <% end %>
    </div>

    <script src="<%= island_src("map_info_button") %>" type="module"></script>
    <script src="<%= island_src("share_buttons") %>" type="module"></script>
    <nav class="pagination is-centered mt-5" role="navigation" aria-label="pagination">
      <% if page > 1 %>
        <a class="pagination-previous" href="/?page=<%= page - 1 %>"><%= t("pagination-previous") %></a>
      <% end %>
      <% if page * per_page < total %>
        <a class="pagination-next" href="/?page=<%= page + 1 %>"><%= t("pagination-next") %></a>
      <% end %>
    </nav>
  </div>
</section>
