<section class="hero">
  <div class="hero-body p-0">
    <%= image_tag "hero.webp", alt: t("app-name"), style: "width: 100%; height: 360px; object-fit: cover; display: block;" %>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 class="title is-4">
      <span class="icon-text">
        <span class="icon"><i class="fa-solid fa-map"></i></span>
        <span><%= t("maps-uploaded-maps") %></span>
      </span>
    </h2>
    <div class="columns is-multiline">
      <% maps.each do |map| %>
        <% user = users_by_id[map.user_id] %>
        <div class="column is-half-tablet is-one-quarter-desktop">
          <%= render "map_card",
                map_ulid: map.ulid,
                map_display_name: map.display_name,
                user_name: user.name,
                author_display_name: profiles_by_user_id[user.id].display_name || user.name,
                author_avatar_url: avatar_urls_by_user_id[user.id],
                thumbnail_url: thumbnail_urls_by_map_ulid[map.ulid],
                metadata_url: metadata_urls_by_map_ulid[map.ulid] %>
        </div>
      <% end %>
    </div>

    <script src="<%= island_src("map_info_button") %>" type="module"></script>
    <script src="<%= island_src("share_buttons") %>" type="module"></script>
    <nav class="pagination is-centered mt-5" role="navigation" aria-label="pagination">
      <% if page > 1 %>
        <a class="pagination-previous" href="/?page=<%= page - 1 %>"><%= t("pagination-previous") %></a>
      <% end %>
      <% if page * per_page < total %>
        <a class="pagination-next" href="/?page=<%= page + 1 %>"><%= t("pagination-next") %></a>
      <% end %>
    </nav>
  </div>
</section>
